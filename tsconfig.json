{
  "compilerOptions": {
    "incremental": true,
    "target": "ES6",
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": false,
    "forceConsistentCasingInFileNames": true,
    "noEmit": true,
    "composite": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "baseUrl": ".",
    "paths": {
      "@/components/*": [
        "components/*"
      ],
      "@/data/*": [
        "data/*"
      ],
      "@/dictionaries/*": [
        "dictionaries/*"
      ],
      "@/lib/*": [
        "lib/*"
      ],
      "@/layouts/*": [
        "layouts/*"
      ],
      "@/css/*": [
        "css/*"
      ],
      "contentlayer/generated": [
        "./.contentlayer/generated"
      ],
      "pliny/*": [
        "node_modules/pliny/*"
      ]
    },
    "plugins": [
      {
        "name": "next"
      }
    ],
    "strictNullChecks": true
  },
  "include": [
    "next-env.d.ts",
    "**/*.js",
    "**/*.mjs",
    "**/*.ts",
    "**/*.tsx",
    "**/*.json",
    ".contentlayer/generated",
    ".contentlayer/generated/**/*.json",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    // Serwist service worker 原始碼本身排除在主專案的型別檢查之外——app/sw.ts 需要
    // webworker 的全域型別(self: ServiceWorkerGlobalScope 等),但整個專案的 lib 是給
    // 一般頁面用的 dom,兩者混在
    // 同一次 tsc 檢查會互相打架。它實際由 app/serwist/[path]/route.ts 的
    // @serwist/turbopack route handler 打包,不經過這裡的 tsc,所以排除掉不影響建置。
    "app/sw.ts"
  ]
}
