{
  "name": "myblog-nextjs",
  "version": "2.4.0",
  "private": true,
  "scripts": {
    "start": "cross-env INIT_CWD=$PWD node ./scripts/dev.mjs",
    "dev": "cross-env INIT_CWD=$PWD node ./scripts/dev.mjs",
    "build": "yarn check:og-font && yarn contentlayer2 build && yarn check:site-font && cross-env INIT_CWD=$PWD next build && cross-env NODE_OPTIONS='--experimental-json-modules' node ./scripts/postbuild.mjs",
    "serve": "next start",
    "test:parity": "playwright test --config=playwright.config.ts",
    "test:unit": "vitest run",
    "check:og-font": "node ./scripts/check-og-font.mjs",
    "check:site-font": "node ./scripts/check-site-font.mjs",
    "update:og-font": "node ./scripts/update-og-font.mjs",
    "update:site-font": "node ./scripts/update-site-font-command.mjs",
    "mermaid:render": "node ./scripts/mermaid-render.mjs",
    "analyze": "cross-env ANALYZE=true next build --webpack",
    "lint": "eslint --fix app components lib layouts scripts",
    "prepare": "husky"
  },
  "dependencies": {
    "@headlessui/react": "2.2.9",
    "@next/bundle-analyzer": "16.2.10",
    "@serwist/turbopack": "^9.5.11",
    "@tailwindcss/forms": "^0.5.11",
    "@tailwindcss/postcss": "^4.1.18",
    "@tailwindcss/typography": "^0.5.19",
    "contentlayer2": "0.5.8",
    "esbuild": "0.28.1",
    "github-slugger": "^2.0.0",
    "gray-matter": "^4.0.3",
    "hast-util-from-html-isomorphic": "^2.0.0",
    "image-size": "2.0.2",
    "kbar": "0.1.0-beta.45",
    "medium-zoom": "^1.1.0",
    "next": "16.2.10",
    "next-themes": "^0.4.6",
    "pliny": "0.4.1",
    "postcss": "8.5.10",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "reading-time": "1.5.0",
    "rehype-autolink-headings": "^7.1.0",
    "rehype-citation": "^2.3.2",
    "rehype-katex": "^7.0.1",
    "rehype-katex-notranslate": "^1.1.4",
    "rehype-preset-minify": "7.0.1",
    "rehype-prism-plus": "^2.0.2",
    "rehype-slug": "^6.0.0",
    "remark": "^15.0.1",
    "remark-gfm": "^4.0.1",
    "remark-github-blockquote-alert": "^2.0.1",
    "remark-math": "^6.0.0",
    "tailwindcss": "^4.1.18",
    "unist-util-visit": "^5.1.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.3",
    "@eslint/js": "^9.18.0",
    "@playwright/test": "^1.61.1",
    "@svgr/webpack": "^8.1.0",
    "@types/mdx": "^2.0.13",
    "@types/react": "^19.2.13",
    "@typescript-eslint/eslint-plugin": "^8.54.0",
    "@typescript-eslint/parser": "^8.54.0",
    "cross-env": "^10.1.0",
    "eslint": "^9.18.0",
    "eslint-config-next": "16.2.10",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-prettier": "^5.5.5",
    "globals": "^17.3.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "mermaid": "^11.16.0",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "rehype-stringify": "^10.0.1",
    "remark-parse": "^11.0.0",
    "remark-rehype": "^11.1.2",
    "serwist": "^9.5.11",
    "typescript": "^5.9.3",
    "unified": "^11.0.5",
    "vitest": "^4.1.10"
  },
  "resolutions": {
    "esbuild": "0.28.1",
    "mdx-bundler/uuid": "11.1.1",
    "pliny/js-yaml": "4.3.0",
    "postcss": "8.5.10"
  },
  "lint-staged": {
    "*.+(js|jsx|ts|tsx)": [
      "yarn eslint --fix"
    ],
    "*.+(js|jsx|ts|tsx|json|css|md|mdx)": [
      "yarn prettier --write"
    ]
  },
  "packageManager": "yarn@3.6.1"
}
