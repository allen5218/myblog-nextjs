# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.js
/.yarn/*
!/.yarn/releases
!/.yarn/plugins
!/.yarn/sdks

# testing
/coverage
/test-results
.playwright-cli/
.superpowers/

# next.js
/.next/
/out/
public/sitemap.xml
.vercel
tsconfig.tsbuildinfo

# Serwist (舊版 webpack service worker 產物;Turbopack route handler 不再產生它)
public/sw*
public/swe-worker*

# production
/build
*.xml

# rss feed
/public/feed.xml

# search
/public/search.json

# misc
.DS_Store

# debug
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# local env files
.env.local
.env.development.local
.env.test.local
.env.production.local

# Contentlayer
.contentlayer

# OpenWiki:生成的 workflow 每次 --init/--update 都被無條件覆寫(手改必被蓋),
# 且它用 Actions 開 PR,需要 repo 層「Allow Actions to create and approve pull
# requests」—— 本專案刻意不開(見 AGENTS.md)。故本機任它重寫,但永不入庫。
/.github/workflows/openwiki-update.yml

# Site-font transactional staging and backups
/.site-font-stage-*/
/public/static/fonts/chiron.backup-*/
/css/chiron-font.generated.css.backup-*
/font-data/chiron/core-codepoints.txt.backup-*
/font-data/chiron/supplemental-assignments.json.backup-*
